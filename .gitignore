# Local environment and secrets
.env
.env.*
!.env.example
auth.json

# Dependency and build output
/vendor/
/node_modules/
/public/build/
/public/hot

# Laravel runtime files
/public/storage
/storage/*.key
/storage/logs/*.log
/bootstrap/cache/*.php
!/bootstrap/cache/.gitignore

