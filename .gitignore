/.phpunit.cache/
.phpunit.result.cache
/coverage/

# Local editor and OS files
/.idea/
/.fleet/
/.vscode/
.DS_Store
Thumbs.db

# Package-manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
